{
  "name": "@kiyotd/wait-define",
  "version": "1.0.1",
  "description": "An asynchronous function that waits until a property of an object is defined.",
  "license": "MIT",
  "private": false,
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "forcePublish": true,
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kiyotd/wait-define.git"
  },
  "bugs": {
    "url": "https://github.com/kiyotd/wait-define/issues"
  },
  "scripts": {
    "test": "jest",
    "coverage": "jest --coverage",
    "build": "node esbuild.config.mjs && tsc --emitDeclarationOnly",
    "publish": "npm publish"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.1.1",
    "@types/eslint": "^9.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@typescript-eslint/typescript-estree": "^8.59.3",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^30.4.2",
    "prettier": "^3.0.3",
    "ts-jest": "^29.1.1",
    "typescript": "^6.0.3"
  },
  "volta": {
    "node": "18.19.0"
  }
}
